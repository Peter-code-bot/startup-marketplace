# === REQUERIDAS ===
# Supabase — obtener de supabase.com/dashboard/project/[ref]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...tu-anon-key-aqui

# URL del sitio (cambiar a tu dominio en producción)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === NOTAS ===
# Google OAuth se configura en Supabase Dashboard → Authentication → Providers → Google
# No se necesitan variables de entorno aquí para OAuth — Supabase lo maneja internamente
